          <mxGeometry x="4638" y="1284" width="23" height="23" as="geometry" />
        </mxCell>
        <mxCell id="cKbgiC5qh_IXnBO1eU4K-139" value="3" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;rounded=1;fillColor=#ff77bf;" parent="1" vertex="1">
