        <mxCell id="-IcYOACd0dDKuoZ8TGqv-74" value="Поток 22. Запрос к сервису обработки заказа. Создание заказа" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
